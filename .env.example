# synthetic-panel works out of the box with local embeddings.
# No API key is required for the default configuration.
SSR_EMBEDDING_PROVIDER=local

# Optional: choose the local sentence-transformers model explicitly.
# SSR_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional API-based embedding providers. These are not required for the default.
# SSR_EMBEDDING_PROVIDER=openai
# SSR_EMBEDDING_MODEL=<provider-embedding-model>
# OPENAI_API_KEY=<your-openai-api-key>

# SSR_EMBEDDING_PROVIDER=gemini
# SSR_EMBEDDING_MODEL=<provider-embedding-model>
# GEMINI_API_KEY=<your-gemini-api-key>
# GOOGLE_API_KEY=<your-google-api-key>
